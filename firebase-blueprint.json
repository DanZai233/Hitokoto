{
  "entities": {
    "quote": {
      "title": "Quote",
      "description": "A quote submitted by a user or admin",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "The quote text" },
        "author": { "type": "string", "description": "Author of the quote" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "submitterId": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["text", "author", "status", "submitterId", "createdAt"]
    },
    "admin": {
      "title": "Admin",
      "description": "Admin users permitted to approve or reject quotes",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin"] }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/quotes/{quoteId}": {
      "schema": "quote",
      "description": "Store all quotes"
    },
    "/admins/{userId}": {
      "schema": "admin",
      "description": "Store admin roles"
    }
  }
}
