rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    // Check if user is an admin by looking at the admins collection
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidQuote(data) {
      return data.keys().hasAll(['text', 'author', 'status', 'submitterId', 'createdAt'])
        && data.keys().size() == 5
        && data.text is string && data.text.size() > 0 && data.text.size() <= 1000
        && data.author is string && data.author.size() <= 100
        && data.status is string && data.status.matches('^(pending|approved|rejected)$')
        && data.submitterId is string && data.submitterId.size() <= 128
        && data.submitterId == request.auth.uid
        && data.createdAt is timestamp;
    }

    match /admins/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /quotes/{quoteId} {
      // Public access to approved quotes
      allow read: if isValidId(quoteId) && (isAdmin() || resource.data.status == 'approved' || (isSignedIn() && resource.data.submitterId == request.auth.uid));
      
      // Allow query lists
      allow list: if (isAdmin() || resource.data.status == 'approved' || (isSignedIn() && resource.data.submitterId == request.auth.uid));

      // Anyone signed in can submit a quote as 'pending'
      // Admin can submit as 'approved'
      allow create: if isSignedIn() && isValidId(quoteId) && isValidQuote(incoming()) && incoming().createdAt == request.time && (
        (incoming().status == 'pending') || (isAdmin() && incoming().status == 'approved')
      );

      // Only admins can update or approve
      allow update: if isSignedIn() && isValidId(quoteId) && (
        (isAdmin() && isValidQuote(incoming()) && incoming().createdAt == existing().createdAt && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'text', 'author']))
      );

      allow delete: if isValidId(quoteId) && isAdmin();
    }
  }
}
